# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Tracing filter (default: info). Try "ferrox=debug,info" while developing.
RUST_LOG=info

# Where ferroxd stores data (objects + sled metadata).
FERROX_DATA_DIR=./data

# HTTP listener.
FERROX_BIND=0.0.0.0:9000

# HTTPS listener (optional). All three must be set together.
# FERROX_TLS_BIND=0.0.0.0:9443
# FERROX_TLS_CERT=/etc/ferrox/server.crt
# FERROX_TLS_KEY=/etc/ferrox/server.key

# Single-tenant identity. Override defaults for anything beyond local dev.
FERROX_ACCESS_KEY=minioadmin
FERROX_SECRET_KEY=minioadmin

# SigV4 clock skew tolerance (seconds). Default 900 (15 min).
FERROX_CLOCK_SKEW_SECS=900

# Call fsync after every object write (true|false). Default true.
FERROX_FSYNC=true

# 64-hex-char AES-256 master key for SSE-S3. Leave unset to disable SSE-S3.
# Generate one with: openssl rand -hex 32
# FERROX_SSE_MASTER_KEY=

# Per-access-key request budget (req/sec). 0 disables rate limiting.
FERROX_MAX_REQ_PER_SEC=0
